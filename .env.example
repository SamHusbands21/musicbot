DISCORD_TOKEN=your_discord_bot_token
# Comma-separated server IDs for instant slash-command registration (recommended for dev)
DISCORD_GUILD_IDS=

LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=changeme
LAVALINK_SECURE=false

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

BOT_LOG_LEVEL=INFO
BOT_PREFIX=!
BOT_IDLE_TIMEOUT_SECONDS=180
BOT_MAX_QUEUE_SIZE=200
BOT_COMMAND_COOLDOWN_SECONDS=3

SQLITE_PATH=/data/bot.db

LAVALINK_SERVER_ADDRESS=0.0.0.0
LAVALINK_SERVER_PORT=2333
LAVALINK_SERVER_PASSWORD=changeme
LAVALINK_PLUGINS_DIR=./plugins
LAVALINK_YOUTUBE_PLUGIN_VERSION=1.11.5
LAVALINK_SPOTIFY_PLUGIN_VERSION=3.2.0
LAVALINK_JAVA_OPTS=-Xms256m -Xmx512m

TTS_VOICE=en-GB-RyanNeural
TTS_HTTP_PORT=8080
TTS_PUBLIC_BASE_URL=http://bot:8080
TTS_STORAGE_DIR=/data/tts
